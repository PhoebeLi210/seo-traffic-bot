# SEO Traffic Bot 环境变量配置

# 代理池配置
PROXY_API_URL=http://127.0.0.1:5010/get
PROXY_POOL_ENABLED=true

# 浏览器配置
HEADLESS=true
BROWSER_TIMEOUT=30000

# 访问频率配置（秒）
MIN_VISIT_INTERVAL=120
MAX_VISIT_INTERVAL=300
MIN_STAY_DURATION=10
MAX_STAY_DURATION=30

# 每日每个网站最大访问次数
MAX_DAILY_VISITS_PER_SITE=20

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/traffic_bot.log
